{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" }
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["(", ")"],
    ["[", "]"]
  ],
  "wordPattern": "[A-Za-z_][A-Za-z0-9_.-]*",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(config|edit)\\b.*$",
    "decreaseIndentPattern": "^\\s*(next|end)\\b\\s*$"
  }
}
